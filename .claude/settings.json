{
  "permissions": {
    "deny": [
      "Bash(git *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-git.sh"
          }
        ]
      }
    ]
  },
  "additionalDirectories": [
    "../zburbach_terraform"
  ]
}
